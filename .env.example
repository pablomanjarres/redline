# ── Redline environment (copy to .env.local; never commit real secrets) ─────────

# Reasoning layer — Claude. Two interchangeable backends; pick one with
# REDLINE_REASONING_BACKEND (anthropic | bedrock), else it auto-selects: the
# Claude API when ANTHROPIC_API_KEY is set, otherwise Bedrock. With neither,
# packages/reasoning falls back to curated, deterministic copy so the app still
# runs and the demo is bulletproof.

# Public path — the first-party Claude API (any Claude key works). This is the
# path to use when running Redline yourself.
# ANTHROPIC_API_KEY=sk-ant-...
# REDLINE_ANTHROPIC_MODEL=claude-opus-4-8   # optional; defaults to Claude Opus 4.8

# Internal path — AWS Bedrock (used by the hosted demo). Standard AWS credential
# chain (env, shared config, SSO, or instance role).
# REDLINE_REASONING_BACKEND=bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# REDLINE_BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-5-20251101-v1:0

# Compute target for the heavy statistical jobs.
# fixture   → locked deterministic demo (default; always available)
# local     → spawn services/rigor locally (real scanpy / PyDESeq2)
# cloudrun  → GCP Cloud Run job
# endpoint  → user-provided SSH/cloud runner (honestly disabled until wired)
REDLINE_COMPUTE_TARGET=fixture

# local target: bridge to the Python rigor engine. REDLINE_ENGINE_CMD is spawned
# per call, fed {op,scenarioId,...} on stdin, returns one ComputeResult JSON. Point
# the per-scenario vars at a built foil .h5ad (see services/rigor/data). Until they
# point at a real file, the app falls back to the fixture.
# REDLINE_ENGINE_CMD=python -m redline.remote_adapter
# REDLINE_MARSON_H5AD=/abs/path/cache/cd4_tcell_perturbseq_subset.foil.h5ad
# REDLINE_KETAMINE_H5AD=/abs/path/pfc_ketamine_scRNAseq.h5ad

# GCP (heavy compute) — only needed when REDLINE_COMPUTE_TARGET=cloudrun
# GCP_PROJECT=
# GCP_REGION=us-east1
# REDLINE_CLOUDRUN_JOB=redline-rigor

# Reference dataset (open S3, no credentials required, MIT licensed)
REDLINE_S3_BUCKET=genome-scale-tcell-perturb-seq
REDLINE_S3_PREFIX=marson2025_data/
