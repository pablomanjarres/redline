# dependencies
node_modules/
.pnpm-store/

# builds
dist/
.next/
.turbo/
out/
*.tsbuildinfo

# python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/
*.egg-info/

# data (never commit datasets)
*.h5ad
*.h5
data/cache/
services/rigor/data/cache/
# ...except the small synthetic benchmark fixtures, which ARE the deliverable
!services/rigor/bench/cases/*.h5ad

# env / secrets
.env
.env.local
.env.*.local
.vercel

# editor / os
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# logs
*.log
npm-debug.log*

# generated foils, oracle outputs, probe scratch (regenerate via build_foils.py / oracle)
services/rigor/cache/

# The self-verification run is COMMITTED, not ignored: a deployed /verifications
# that renders an empty state proves nothing to anyone who opens it. Regenerate
# with `pnpm --filter @redline/verify run verify` and commit the result.

# pr-watch runtime state: watermark, heartbeat, per-PR loop logs, kill switch.
# Runtime state never goes in a skill directory, and never in git.
.claude/pr-watch/seen
.claude/pr-watch/queue
.claude/pr-watch/heartbeat
.claude/pr-watch/logs/
.claude/pr-watch/DISABLED

# playwright mcp screenshots (local only)
.playwright-mcp/
