{
  "name": "@redline/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": ["*.css"],
  "description": "Redline design system — tokens, palette, and shared primitives.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "lint": "echo \"lint placeholder\"",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@redline/contracts": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
