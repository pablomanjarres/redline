{
  "name": "@redline/critic-verify",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The actor-critic acceptance harness: proves the critic can veto and downgrade over the four seeded foils plus adversarial injections, and catches a rubber-stamp.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "lint": "echo \"lint placeholder\"",
    "test": "vitest run",
    "verify": "pnpm build && node dist/verify.js"
  },
  "dependencies": {
    "@redline/contracts": "workspace:*",
    "@redline/engine": "workspace:*",
    "@redline/reasoning": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
